# ─────────────────────────────────────────────────────────────────────────────
# Bezoom – Environment Variables for Local Development
# Copy to .env.local and adjust values as needed.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=bezoom
POSTGRES_PASSWORD=bezoom_dev
POSTGRES_PORT=5432
# PgBouncer is not used in local dev (connect directly to postgres:5432)

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_dev
REDIS_PORT=6379

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_dev
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Keycloak ──────────────────────────────────────────────────────────────
# Keycloak admin credentials (development only)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme
KEYCLOAK_HTTP_PORT=8080
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=bezoom
KEYCLOAK_CLIENT_ID=bezoom-api
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_SWAGGER_CLIENT_ID=bezoom-web

# ── Mailpit ───────────────────────────────────────────────────────────────────
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# ── Redis Commander (queue/key browser) ──────────────────────────────────────
REDIS_COMMANDER_PORT=3010

# ── Next.js Web ───────────────────────────────────────────────────────────────
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── NestJS API ────────────────────────────────────────────────────────────
API_PORT=4000

# ── HuggingFace (for moderation services) ────────────────────────────────────
# HF_TOKEN=hf_your_token_here

# ── Maps (profile: maps) ─────────────────────────────────────────────────────
# Override to use a smaller/different region:
# NOMINATIM_PBF_URL=https://download.geofabrik.de/europe/poland-latest.osm.pbf
NOMINATIM_DB_PASSWORD=nominatim_dev
NOMINATIM_PORT=8080
OSRM_PORT=5000

# ── pgAdmin (profile: tools) ──────────────────────────────────────────────────
PGADMIN_EMAIL=admin@bezoom.local
PGADMIN_PASSWORD=pgadmin_dev
PGADMIN_PORT=5050

# ── Redis Insight (profile: tools) ───────────────────────────────────────────
REDIS_INSIGHT_PORT=8001
