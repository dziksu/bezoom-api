{
  "realm": "bezoom",
  "enabled": true,
  "displayName": "Bezoom (Dev)",
  "displayNameHtml": "<b>Bezoom Dev</b>",

  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "resetPasswordAllowed": true,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "editUsernameAllowed": false,
  "rememberMe": true,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "failureFactor": 5,

  "sslRequired": "none",
  "internationalizationEnabled": false,

  "accessTokenLifespan": 1800,
  "accessTokenLifespanForImplicitFlow": 900,
  "ssoSessionIdleTimeout": 3600,
  "ssoSessionMaxLifespan": 43200,
  "offlineSessionIdleTimeout": 2592000,
  "offlineSessionMaxLifespanEnabled": true,
  "offlineSessionMaxLifespan": 5184000,
  "actionTokenGeneratedByAdminLifespan": 43200,
  "actionTokenGeneratedByUserLifespan": 300,

  "revokeRefreshToken": true,
  "refreshTokenMaxReuse": 0,

  "defaultSignatureAlgorithm": "RS256",

  "roles": {
    "realm": [
      { "name": "user", "description": "Default role for all authenticated users" },
      { "name": "admin", "description": "Full administrative access across the platform" }
    ],
    "client": {
      "nestjs-api": [
        { "name": "read:orders", "description": "Can read order data" },
        { "name": "write:orders", "description": "Can create/modify order data" },
        { "name": "read:users", "description": "Can read user profile data" },
        { "name": "manage:users", "description": "Can manage other users (admin-level API access)" }
      ]
    }
  },

  "defaultRole": {
    "name": "default-roles-bezoom",
    "description": "Default composite role granted to every new user",
    "composite": true,
    "clientRole": false,
    "composites": {
      "realm": ["user"]
    }
  },

  "clientScopes": [
    {
      "name": "nestjs-api-audience",
      "description": "Adds nestjs-api as an audience in issued tokens",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "audience-nestjs-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "nestjs-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "roles-claims",
      "description": "Ensures realm_access and resource_access roles are present on access tokens",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String"
          }
        },
        {
          "name": "client-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-client-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "claim.name": "resource_access.${client_id}.roles",
            "jsonType.label": "String",
            "usermodel.clientRoleMapping.clientId": "nestjs-api"
          }
        }
      ]
    }
  ],

  "clients": [
    {
      "clientId": "nestjs-web",
      "name": "Bezoom Next.js Frontend (Dev)",
      "description": "Confidential client used by the Next.js app on localhost:3000 (Auth.js/next-auth server-side code exchange)",
      "enabled": true,
      "protocol": "openid-connect",

      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "dev-nestjs-web-secret",

      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,

      "redirectUris": ["http://localhost:3000/api/auth/callback/keycloak", "http://localhost:3000/*"],
      "webOrigins": ["http://localhost:3000", "+"],
      "rootUrl": "http://localhost:3000",
      "baseUrl": "/",
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:3000",
        "pkce.code.challenge.method": "S256"
      },

      "defaultClientScopes": ["web-origins", "acr", "profile", "email", "roles", "nestjs-api-audience", "roles-claims"],
      "optionalClientScopes": ["address", "phone", "offline_access", "microprofile-jwt"]
    },
    {
      "clientId": "nestjs-api",
      "name": "Bezoom NestJS API (Dev)",
      "description": "Resource-server client for the NestJS API on localhost:4000. Not used for interactive login — defines audience/roles and a service account for machine-to-machine calls if needed.",
      "enabled": true,
      "protocol": "openid-connect",

      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "dev-nestjs-api-secret",

      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,

      "redirectUris": ["http://localhost:4000/*"],
      "webOrigins": ["http://localhost:4000"],
      "rootUrl": "http://localhost:4000",

      "defaultClientScopes": ["web-origins", "acr", "profile", "email", "roles"],
      "optionalClientScopes": ["offline_access", "microprofile-jwt"]
    }
  ],

  "users": [
    {
      "username": "admin@bezoom.com",
      "email": "admin@bezoom.com",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Bezoom",
      "lastName": "Admin",
      "credentials": [{ "type": "password", "value": "Test1234!", "temporary": false }],
      "realmRoles": ["user", "admin"],
      "clientRoles": {
        "nestjs-api": ["read:orders", "write:orders", "read:users", "manage:users"]
      }
    },
    {
      "username": "user@bezoom.com",
      "email": "user@bezoom.com",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Test",
      "lastName": "User",
      "credentials": [{ "type": "password", "value": "Test1234!", "temporary": false }],
      "realmRoles": ["user"],
      "clientRoles": {
        "nestjs-api": ["read:orders"]
      }
    }
  ]
}
